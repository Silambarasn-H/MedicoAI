{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "MedicoAI – Auth Module",
    "description": "Authentication API tests for MedicoAI Hospital Management System.\n\nBase URL: http://localhost:8080/api\n\nWorkflow:\n1. Run 'Register Patient' (or Admin/Doctor)\n2. Run 'Login' – token is auto-saved to {{authToken}}\n3. All subsequent requests use {{authToken}} automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string",
      "description": "JWT token – auto-populated by the Login request test script"
    }
  ],
  "item": [
    {
      "name": "1. Register Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response has success true', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.be.true;",
              "});",
              "",
              "pm.test('Response contains accessToken', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.data).to.have.property('accessToken');",
              "    pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.test('Role is ADMIN', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.data.role).to.eql('ADMIN');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"System Admin\",\n  \"email\": \"admin@medicoai.com\",\n  \"password\": \"Admin@1234\",\n  \"phone\": \"9000000001\",\n  \"role\": \"ADMIN\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register"]
        },
        "description": "Registers a new Admin user.\n\nExpected: 201 Created with JWT token in response body."
      },
      "response": [
        {
          "name": "201 – Admin Registered",
          "status": "Created",
          "code": 201,
          "header": [
            { "key": "Content-Type", "value": "application/json" }
          ],
          "body": "{\n  \"success\": true,\n  \"message\": \"Registration successful\",\n  \"data\": {\n    \"accessToken\": \"eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJhZG1pbkBtZWRpY29haS5jb20ifQ.signature\",\n    \"tokenType\": \"Bearer\",\n    \"userId\": 1,\n    \"fullName\": \"System Admin\",\n    \"email\": \"admin@medicoai.com\",\n    \"role\": \"ADMIN\",\n    \"message\": \"Registration successful\"\n  },\n  \"timestamp\": \"2024-01-15T10:00:00\"\n}"
        },
        {
          "name": "400 – Email Already Registered",
          "status": "Bad Request",
          "code": 400,
          "header": [
            { "key": "Content-Type", "value": "application/json" }
          ],
          "body": "{\n  \"success\": false,\n  \"message\": \"Email 'admin@medicoai.com' is already registered.\",\n  \"timestamp\": \"2024-01-15T10:00:00\"\n}"
        }
      ]
    },
    {
      "name": "2. Register Doctor",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response has success true', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.be.true;",
              "});",
              "",
              "pm.test('Role is DOCTOR', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.data.role).to.eql('DOCTOR');",
              "});",
              "",
              "pm.test('accessToken is present', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Dr. Priya Sharma\",\n  \"email\": \"doctor@medicoai.com\",\n  \"password\": \"Doctor@1234\",\n  \"phone\": \"9000000002\",\n  \"role\": \"DOCTOR\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register"]
        },
        "description": "Registers a new Doctor user.\n\nExpected: 201 Created with JWT token and role DOCTOR."
      },
      "response": [
        {
          "name": "201 – Doctor Registered",
          "status": "Created",
          "code": 201,
          "header": [
            { "key": "Content-Type", "value": "application/json" }
          ],
          "body": "{\n  \"success\": true,\n  \"message\": \"Registration successful\",\n  \"data\": {\n    \"accessToken\": \"eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJkb2N0b3JAbWVkaWNvYWkuY29tIn0.signature\",\n    \"tokenType\": \"Bearer\",\n    \"userId\": 2,\n    \"fullName\": \"Dr. Priya Sharma\",\n    \"email\": \"doctor@medicoai.com\",\n    \"role\": \"DOCTOR\",\n    \"message\": \"Registration successful\"\n  },\n  \"timestamp\": \"2024-01-15T10:01:00\"\n}"
        }
      ]
    },
    {
      "name": "3. Register Patient",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
