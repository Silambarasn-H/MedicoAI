        "description": "Public endpoint – no token required.\nUse this to verify the backend is up before running other tests."
      },
      "response": [
        {
          "name": "200 – Service Running",
          "status": "OK",
          "code": 200,
          "header": [
            { "key": "Content-Type", "value": "application/json" }
          ],
          "body": "{\n  \"success\": true,\n  \"message\": \"Auth service is running\",\n  \"data\": \"OK\",\n  \"timestamp\": \"2024-01-15T10:00:00\"\n}"
        }
