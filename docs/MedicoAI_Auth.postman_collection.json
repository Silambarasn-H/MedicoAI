              "    pm.expect(json.success).to.be.true;",
              "    pm.expect(json.data).to.eql('OK');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/auth/health",
          "host": ["{{baseUrl}}"],
